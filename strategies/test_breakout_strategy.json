  "backtest": {
    "period_days": 2920,
    "initial_capital": 10000,
    "slippage": 0.001,
    "commission": 0.0004,
    "funding_rate": 0.0001
  },
  "performance_targets": {
    "target_annual_return": 1.0,
    "max_acceptable_drawdown": 0.5,
    "min_win_rate": 0.45,
    "min_profit_factor": 2.5,
    "min_sharpe_ratio": 1.5,
    "target_trades_per_year": 50
  }
