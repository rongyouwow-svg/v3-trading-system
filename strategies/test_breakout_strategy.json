  "entry": {
    "type": "breakout",
    "indicators": [],
    "rules": [],
    "min_score": 75,
    "required_confirmations": 4,
    "thresholds": {}
  },
  "exit": {
    "stop_loss": {
      "type": "fixed",
      "fixed_pct": 0.05
    },
    "take_profit": {
      "type": "rrr",
      "target_rrr": 3.0
    },
    "signal_reverse": true
  },
  "position_sizing": {
    "method": "dynamic",
    "base_size": 0.3,
    "max_size": 0.6,
    "min_size": 0.1,
    "risk_per_trade": 0.02,
    "kelly_divisor": 2.0,
    "kelly_max": 0.25,
    "dynamic_adjustments": {}
  },
  "risk_management": {
    "daily_limits": {
      "max_loss_pct": 0.05,
      "max_trades": 5
    },
    "consecutive_losses": {
      "pause_after": 3,
      "pause_duration_hours": 24,
      "reduce_size_after": 2,
      "reduction_factor": 0.5
    },
    "drawdown_control": [
      {
        "threshold": 0.15,
        "action": "reduce_50"
      },
      {
        "threshold": 0.25,
        "action": "reduce_75"
      },
      {
        "threshold": 0.4,
        "action": "stop_trading"
      }
    ],
    "correlation_limit": 0.8,
    "max_positions": 3,
    "max_exposure": 1.2
