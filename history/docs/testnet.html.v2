<!DOCTYPE html>
<html lang="zh-CN" data-version="20260310-1550">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🧪 测试网交易 - 币安量化系统</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: linear-gradient(135deg, #0a1a2e, #163e2e, #0f3460);
            color: #fff;
            padding: 20px;
            min-height: 100vh;
        }
        .container { max-width: 1600px; margin: 0 auto; }
        
        /* 导航栏 */
        .nav {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 20px;
        }
        .nav a {
            padding: 10px 20px;
            background: rgba(255,255,255,0.1);
            color: #fff;
            text-decoration: none;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.2);
        }
        .nav a.active {
            background: #00ff88;
            border-color: #00ff88;
            color: #000;
        }
        
        /* 页面头部 */
        .header {
            text-align: center;
            padding: 20px;
            margin-bottom: 20px;
            background: linear-gradient(135deg, rgba(0,255,136,0.1), rgba(0,255,136,0.05));
            border: 2px solid #00ff88;
            border-radius: 16px;
        }
        .header h1 { color: #00ff88; font-size: 28px; margin-bottom: 10px; }
        .header p { color: #aaa; }
        
        /* 面板样式 */
        .panel {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
        }
        .panel h3 { color: #00ff88; margin-bottom: 15px; font-size: 18px; }
        
        /* 三栏布局 */
        .main-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 20px;
            height: 55vh;
        }
        .column {
            display: flex;
            flex-direction: column;
            gap: 20px;
            overflow: hidden;
        }
        .column .panel {
            flex: 1;
            overflow-y: auto;
            margin-bottom: 0;
        }
        
        /* 底部交易记录 */
        .trades-section {
            height: 35vh;
            overflow-y: auto;
        }
        
        /* 表格样式 */
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }
        th {
            background: rgba(0,255,136,0.1);
            color: #00ff88;
            padding: 10px;
            text-align: left;
            position: sticky;
            top: 0;
        }
        td {
            padding: 8px 10px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        tr:hover {
            background: rgba(255,255,255,0.03);
        }
        
        /* 卡片样式 */
        .card {
            background: rgba(255,255,255,0.03);
            border-left: 3px solid #00ff88;
            padding: 12px;
            border-radius: 6px;
            margin-bottom: 10px;
        }
        .card.short { border-left-color: #ff4757; }
        
        /* 按钮样式 */
        .btn {
            background: #00ff88;
            color: #000;
            border: none;
            padding: 10px 20px;
            border-radius: 6px;
            cursor: pointer;
            font-weight: bold;
        }
        .btn:hover { background: #00cc6a; }
        .btn-danger { background: #ff4757; }
        .btn-danger:hover { background: #cc3a46; }
        
        /* 表单样式 */
        input, select {
            width: 100%;
            padding: 10px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 6px;
            color: #fff;
            margin-bottom: 10px;
        }
        
        /* 滚动条样式 */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: rgba(255,255,255,0.03); }
        ::-webkit-scrollbar-thumb { background: rgba(0,255,136,0.3); border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(0,255,136,0.5); }
        
        /* 空状态 */
        .empty {
            color: #666;
            text-align: center;
            padding: 40px;
        }
        
        /* 响应式 */
        @media (max-width: 1200px) {
            .main-grid {
                grid-template-columns: repeat(2, 1fr);
                height: auto;
            }
        }
        @media (max-width: 768px) {
            .main-grid {
                grid-template-columns: 1fr;
                height: auto;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- 导航栏 -->
        <div class="nav">
            <a href="/">🏠 首页</a>
            <a href="testnet.html" class="active">🧪 测试网</a>
            <a href="real.html">🔴 实盘</a>
        </div>
        
        <!-- 页面头部 -->
        <div class="header">
            <h1>🧪 测试网交易</h1>
            <p>币安量化交易系统 - 测试环境</p>
        </div>
        
        <!-- 主内容区（三栏布局） -->
        <div class="main-grid">
            <!-- 左栏：账户资产 -->
            <div class="column">
                <div class="panel">
                    <h3>💰 账户资产</h3>
                    <div id="account-info">加载中...</div>
                </div>
            </div>
            
            <!-- 中栏：策略控制 -->
            <div class="column">
                <div class="panel">
                    <h3>🎯 策略控制</h3>
                    <label style="display: block; color: #aaa; margin-bottom: 5px; font-size: 14px;">交易对</label>
                    <select id="symbol">
                        <option value="ETHUSDT">ETHUSDT</option>
                        <option value="BTCUSDT">BTCUSDT</option>
                        <option value="LINKUSDT">LINKUSDT</option>
                        <option value="AVAXUSDT">AVAXUSDT</option>
                    </select>
                    
                    <label style="display: block; color: #aaa; margin-bottom: 5px; font-size: 14px;">策略</label>
                    <select id="strategy">
                        <option value="auto_sim">🤖 自动交易模拟</option>
                        <option value="v23 高频">📈 v23 高频策略</option>
                    </select>
                    
                    <label style="display: block; color: #aaa; margin-bottom: 5px; font-size: 14px;">杠杆</label>
                    <input type="number" id="leverage" value="4" min="1" max="20">
                    
                    <label style="display: block; color: #aaa; margin-bottom: 5px; font-size: 14px;">金额 (USDT)</label>
                    <input type="number" id="amount" value="500" min="100" max="10000">
                    
                    <div style="display: flex; gap: 10px; margin-top: 15px;">
                        <button class="btn" onclick="startStrategy()" style="flex: 1;">▶️ 启动</button>
                        <button class="btn btn-danger" onclick="stopStrategy()" style="flex: 1;">⏹️ 停止</button>
                    </div>
                </div>
            </div>
            
            <!-- 右栏：活跃策略 + 持仓 + 委托单 -->
            <div class="column">
                <div class="panel" style="flex: 0 0 auto;">
                    <h3>🔥 活跃策略</h3>
                    <div id="active-strategies-list">
                        <div class="empty">加载中...</div>
                    </div>
                </div>
                <div class="panel">
                    <h3>📊 当前持仓</h3>
                    <div id="positions-list">
                        <div class="empty">加载中...</div>
                    </div>
                </div>
                <div class="panel">
                    <h3>📋 委托单（含止损）</h3>
                    <div id="algo-orders-list">
                        <div class="empty">加载中...</div>
                    </div>
                    <button class="btn" onclick="loadAlgoOrders()" style="margin-top: 10px; width: 100%;">🔄 刷新</button>
                </div>
            </div>
        </div>
        
        <!-- 底部：交易记录 -->
        <div class="panel trades-section">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                <h3 style="margin: 0;">📝 交易记录</h3>
                <button class="btn" onclick="loadTrades()" style="padding: 5px 15px; font-size: 13px;">🔄 刷新</button>
            </div>
            <div style="overflow-x: auto;">
                <table>
                    <thead>
                        <tr>
                            <th>时间</th>
                            <th>交易对</th>
                            <th>方向</th>
                            <th>类型</th>
                            <th>数量</th>
                            <th>价格</th>
                            <th>盈亏</th>
                            <th>状态</th>
                        </tr>
                    </thead>
                    <tbody id="trades-list">
                        <tr><td colspan="8" class="empty">加载中...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <script>
        const API_BASE = '/api';
        
        // 加载账户信息
        async function loadAccount() {
            try {
                const resp = await fetch(`${API_BASE}/testnet/account?t=${Date.now()}`);
                const data = await resp.json();
                
                if (data.success && data.account && data.account.balances) {
                    const balances = data.account.balances;
                    const usdt = balances.find(b => b.asset === 'USDT');
                    const usdc = balances.find(b => b.asset === 'USDC');
                    const total = (usdt?.total || 0) + (usdc?.total || 0);
                    const available = (usdt?.free || 0) + (usdc?.free || 0);
                    
                    document.getElementById('account-info').innerHTML = `
                        <div class="card" style="margin-bottom: 10px;">
                            <div style="font-size: 24px; color: #00ff88; font-weight: bold;">💰 $${total.toFixed(2)}</div>
                            <div style="color: #aaa; font-size: 14px; margin-top: 5px;">总资产</div>
                        </div>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                            <div class="card">
                                <div style="font-size: 16px; color: #fff;">$${usdt?.total.toFixed(2) || '0.00'}</div>
                                <div style="color: #aaa; font-size: 12px;">USDT</div>
                            </div>
                            <div class="card">
                                <div style="font-size: 16px; color: #fff;">$${usdc?.total.toFixed(2) || '0.00'}</div>
                                <div style="color: #aaa; font-size: 12px;">USDC</div>
                            </div>
                        </div>
                        <div class="card" style="margin-top: 10px; border-left-color: #00cc6a;">
                            <div style="color: #aaa; font-size: 13px;">可用资金</div>
                            <div style="color: #00ff88; font-size: 18px; font-weight: bold;">$${available.toFixed(2)}</div>
                        </div>
                    `;
                }
            } catch (e) {
                console.error('加载账户失败:', e);
                document.getElementById('account-info').innerHTML = '<div class="empty">加载失败</div>';
            }
        }
        
        // 加载持仓
        async function loadPositions() {
            try {
                const resp = await fetch(`${API_BASE}/testnet/positions`);
                const data = await resp.json();
                
                if (data.success && data.positions && data.positions.length > 0) {
                    document.getElementById('positions-list').innerHTML = data.positions.map(p => `
                        <div class="card ${p.side === 'SHORT' ? 'short' : ''}">
                            <div style="font-size: 18px; font-weight: bold; margin-bottom: 5px;">
                                ${p.symbol} ${p.side}
                            </div>
                            <div style="color: #aaa; font-size: 14px;">
                                数量：${p.size} | 入场：$${p.entry_price}
                            </div>
                            <div style="color: ${p.unrealized_pnl >= 0 ? '#00ff88' : '#ff4757'}; font-size: 14px; font-weight: bold; margin-top: 5px;">
                                盈亏：$${p.unrealized_pnl?.toFixed(2) || '0.00'} (${((p.unrealized_pnl / (p.entry_price * p.size)) * 100)?.toFixed(2) || '0'}%)
                            </div>
                            <div style="color: #666; font-size: 12px; margin-top: 5px; display: flex; justify-content: space-between;">
                                <span>杠杆：${p.leverage || 1}x</span>
                                <span>仓位：$${p.position_value?.toFixed(2) || '0.00'}</span>
                            </div>
                        </div>
                    `).join('');
                } else {
                    document.getElementById('positions-list').innerHTML = '<div class="empty">无持仓</div>';
                }
            } catch (e) {
                console.error('加载持仓失败:', e);
                document.getElementById('positions-list').innerHTML = '<div class="empty">加载失败</div>';
            }
        }
        
        // 加载委托单
        async function loadAlgoOrders() {
            try {
                const symbol = document.getElementById('symbol').value || 'ETHUSDT';
                const resp = await fetch(`${API_BASE}/binance/algo-orders?symbol=${symbol}&limit=20`);
                const data = await resp.json();
                
                if (data.success && data.orders && data.orders.length > 0) {
                    document.getElementById('algo-orders-list').innerHTML = data.orders.map(o => {
                        const typeLabel = o.orderType === 'STOP_MARKET' ? '🔴 止损' : 
                                         o.orderType === 'TAKE_PROFIT_MARKET' ? '🟢 止盈' : '📋 条件单';
                        return `
                        <div class="card ${o.orderType === 'STOP_MARKET' ? 'short' : ''}">
                            <div style="font-size: 16px; font-weight: bold; margin-bottom: 5px;">
                                ${typeLabel} ${o.symbol}
                            </div>
                            <div style="color: #aaa; font-size: 14px;">
                                方向：${o.side} | 触发价：$${o.triggerPrice}
                            </div>
                            <div style="color: #666; font-size: 12px; margin-top: 5px; display: flex; justify-content: space-between;">
                                <span>数量：${o.quantity}</span>
                                <span>状态：${o.algoStatus}</span>
                            </div>
                        </div>
                        `;
                    }).join('');
                } else {
                    document.getElementById('algo-orders-list').innerHTML = '<div class="empty">无委托单</div>';
                }
            } catch (e) {
                console.error('加载委托单失败:', e);
                document.getElementById('algo-orders-list').innerHTML = '<div class="empty">加载失败</div>';
            }
        }
        
        // 加载交易记录
        async function loadTrades() {
            try {
                const resp = await fetch(`${API_BASE}/trades?limit=50`);
                const data = await resp.json();
                
                if (data.success && data.trades && data.trades.length > 0) {
                    document.getElementById('trades-list').innerHTML = data.trades.map(t => {
                        const pnlClass = t.pnl > 0 ? '#00ff88' : (t.pnl < 0 ? '#ff4757' : '#aaa');
                        const pnlText = t.pnl !== undefined && t.pnl !== 0 ? `$${t.pnl.toFixed(2)}` : '-';
                        return `
                        <tr>
                            <td style="color: #aaa;">${new Date(t.timestamp).toLocaleTimeString()}</td>
                            <td style="font-weight: bold;">${t.symbol}</td>
                            <td><span style="color: ${t.side === 'LONG' ? '#00ff88' : '#ff4757'};">${t.side}</span></td>
                            <td>${t.action}</td>
                            <td>${t.quantity?.toFixed(4) || '0'}</td>
                            <td>$${t.price?.toFixed(2) || '0'}</td>
                            <td style="color: ${pnlClass}; font-weight: bold;">${pnlText}</td>
                            <td>${t.status === 'executed' ? '✅ 成交' : t.status}</td>
                        </tr>
                        `;
                    }).join('');
                } else {
                    document.getElementById('trades-list').innerHTML = '<tr><td colspan="8" class="empty">无交易记录</td></tr>';
                }
            } catch (e) {
                console.error('加载交易记录失败:', e);
                document.getElementById('trades-list').innerHTML = '<tr><td colspan="8" class="empty">加载失败</td></tr>';
            }
        }
        
        // 启动策略
        async function startStrategy() {
            const symbol = document.getElementById('symbol').value;
            const strategy = document.getElementById('strategy').value;
            const leverage = document.getElementById('leverage').value;
            const amount = document.getElementById('amount').value;
            
            if (!confirm(`确定要启动 ${symbol} 的 ${strategy} 吗？\n\n杠杆：${leverage}x\n金额：$${amount}`)) {
                return;
            }
            
            try {
                const resp = await fetch(`${API_BASE}/strategy/start`, {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({
                        symbol: symbol,
                        strategy: strategy,
                        leverage: parseInt(leverage),
                        amount: parseFloat(amount),
                        account_type: '测试盘'
                    })
                });
                
                const data = await resp.json();
                
                if (data.success) {
                    alert(`✅ 策略已启动\n\n${symbol} ${strategy}\n杠杆：${leverage}x\n金额：$${amount}`);
                    loadAccount();
                    loadPositions();
                    loadAlgoOrders();
                } else {
                    alert(`❌ 启动失败：${data.error || '未知错误'}`);
                }
            } catch (e) {
                alert(`❌ 启动失败：${e.message}`);
            }
        }
        
        // 停止策略
        async function stopStrategy() {
            const symbol = document.getElementById('symbol').value;
            
            if (!confirm(`确定要停止 ${symbol} 的策略吗？\n\n这将平仓并记录交易记录。`)) {
                return;
            }
            
            try {
                const resp = await fetch(`${API_BASE}/strategy/stop`, {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({
                        symbol: symbol,
                        account_type: '测试盘'
                    })
                });
                
                const data = await resp.json();
                
                if (data.success) {
                    alert(`✅ 策略已停止\n\n${symbol} 已平仓\n盈亏：$${data.pnl?.toFixed(2) || '0.00'}`);
                    loadAccount();
                    loadPositions();
                    loadAlgoOrders();
                } else {
                    alert(`❌ 停止失败：${data.error || '未知错误'}`);
                }
            } catch (e) {
                alert(`❌ 停止失败：${e.message}`);
            }
        }
        
        // 加载活跃策略
        async function loadActiveStrategies() {
            try {
                const resp = await fetch(`${API_BASE}/strategy/list`);
                const data = await resp.json();
                
                if (data.success && data.strategies && data.strategies.length > 0) {
                    document.getElementById('active-strategies-list').innerHTML = data.strategies.map(s => {
                        const pnlClass = s.pnl >= 0 ? '#00ff88' : '#ff4757';
                        return `
                        <div class="card" style="margin-bottom: 10px;">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                                <div style="font-size: 16px; font-weight: bold;">${s.symbol} ${s.strategy}</div>
                                <button onclick="stopStrategyBySymbol('${s.symbol}')" class="btn btn-danger" style="padding: 5px 10px; font-size: 12px;">⏹️ 停止</button>
                            </div>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; font-size: 13px;">
                                <div style="color: #aaa;">方向：<span style="color: ${s.side === 'long' ? '#00ff88' : '#ff4757'};">${s.side.toUpperCase()}</span></div>
                                <div style="color: #aaa;">杠杆：${s.leverage || 1}x</div>
                                <div style="color: #aaa;">入场：$${s.entry_price}</div>
                                <div style="color: #aaa;">数量：${s.quantity?.toFixed(4) || '0'}</div>
                            </div>
                            <div style="margin-top: 8px; padding-top: 8px; border-top: 1px solid rgba(255,255,255,0.1);">
                                <div style="color: ${pnlClass}; font-size: 16px; font-weight: bold;">盈亏：$${s.pnl?.toFixed(2) || '0.00'} (${s.pnl_pct?.toFixed(2) || '0'}%)</div>
                            </div>
                        </div>
                        `;
                    }).join('');
                } else {
                    document.getElementById('active-strategies-list').innerHTML = '<div class="empty">无活跃策略</div>';
                }
            } catch (e) {
                console.error('加载活跃策略失败:', e);
                document.getElementById('active-strategies-list').innerHTML = '<div class="empty">加载失败</div>';
            }
        }
        
        // 停止指定策略
        async function stopStrategyBySymbol(symbol) {
            if (!confirm(`确定要停止 ${symbol} 的策略吗？`)) {
                return;
            }
            
            try {
                const resp = await fetch(`${API_BASE}/strategy/stop`, {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({
                        symbol: symbol,
                        account_type: '测试盘'
                    })
                });
                
                const data = await resp.json();
                
                if (data.success) {
                    alert(`✅ 策略已停止\n${symbol} 盈亏：$${data.pnl?.toFixed(2) || '0.00'}`);
                    loadActiveStrategies();
                    loadPositions();
                    loadAlgoOrders();
                } else {
                    alert(`❌ 停止失败：${data.error}`);
                }
            } catch (e) {
                alert(`❌ 停止失败：${e.message}`);
            }
        }
        
        // 页面加载时执行
        loadAccount();
        loadPositions();
        loadActiveStrategies();
        loadAlgoOrders();
        loadTrades();
        
        // 每 30 秒刷新一次
        setInterval(() => {
            loadAccount();
            loadPositions();
            loadActiveStrategies();
            loadTrades();
        }, 30000);
    </script>
</body>
</html>
